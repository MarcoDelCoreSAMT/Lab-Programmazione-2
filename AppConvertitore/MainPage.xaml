<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppConvertitore.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="80,0"
            Spacing="50" VerticalOptions="Center">
            

            <Label
                Text="Convertitore Franchi - Euro"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

            <Entry
                x:Name="entConversione"
                Keyboard="Numeric"
                Placeholder="Inserisci importo in CHF"
            />

            <Button
                x:Name="btnConverti"
                Text="Converti in euro"
                TextColor="GhostWhite"
                BackgroundColor="DarkBlue"
                Clicked="btnConverti_Clicked"
            />

            <Button
                x:Name="BtnReset"
                Text="Pulisci"
                TextColor="GhostWhite"
                BackgroundColor="Magenta"
                Clicked="BtnReset_Clicked"
            />

            <Label 
                x:Name="lblRisultato"
                Text="Risultato: --"
                FontSize="20"
                HorizontalOptions="Center"
                Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
