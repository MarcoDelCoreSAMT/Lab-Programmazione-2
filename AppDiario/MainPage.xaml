<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppDiario.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="30">

            <Label
                Text="IL MIO DIARIO"
                FontSize="24"
                HorizontalOptions="Center"
                FontAttributes="Bold"/>

            <Entry x:Name="EntTitolo"
                   Placeholder="Inserisci Titolo"/>
            <Entry x:Name="EntTesto"
                Placeholder="Inserisci Testo"/>
            
            <Button x:Name="btnSalva"
                Text="SALVA NOTA"
                Clicked="OnSalvaClicked"
                TextColor="White"
                BackgroundColor="Green"/>

            <Button x:Name="btnLeggi"
                Text="LEGGI TUTTE LE NOTE"
                Clicked="OnLeggiClicked"
                BackgroundColor="Grey"
                TextColor="White"
                />
            
            <!-- Equivalente a <hr> in HTML -->
            <BoxView HeightRequest="1"
                     Color="Silver"/>

            <Label Text="Note salvate nel file: "
                   FontAttributes="Italic"/>

            <Editor x:Name="editDisplay"
                    HeightRequest="300"
                    IsReadOnly="True"
                    BackgroundColor="GhostWhite"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
