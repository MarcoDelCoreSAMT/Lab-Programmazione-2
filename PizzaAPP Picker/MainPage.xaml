<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzaAPP_Picker.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            
            <Label Text="Menu Pizze"
                FontSize="24"
                Padding="15"
                HorizontalOptions="Center"/>

            <BoxView
                Color="Grey"
                WidthRequest="1375"
                HeightRequest="1"/>

            <Picker x:Name="PizzaPicker"
                    Title="Seleziona il tipo di pizza"
                    WidthRequest="400"
                    ItemDisplayBinding="{Binding Nome}"
                    HorizontalOptions="Start"
                    SelectedIndexChanged="OnSelectedIndexChanged"/>

            <Image x:Name="imgPizza"
                WidthRequest="150"
                HeightRequest="150"
                HorizontalOptions="Start"
                Margin="10"/>
            <Label x:Name="lbPizzaNome"/>
            <Label x:Name="lbPizzaPrezzo"/>
            <Label x:Name="lbIngredienti"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
