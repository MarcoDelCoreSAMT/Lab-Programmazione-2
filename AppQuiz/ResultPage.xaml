<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppQuiz.ResultPage"
             Title="ResultPage">
    <VerticalStackLayout Padding="30,0" Spacing="25">
        <Label 
            Text="QUIZ COMPLETATO!"
            FontSize="24"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Frame CornerRadius="20"
               Padding="25"
               BackgroundColor="WhiteSmoke"
               HasShadow="True">

            <VerticalStackLayout>
                <Label 
                    Text="Il tuo punteggio è:"
                    FontSize="18"
                    TextColor="Gray"
                    VerticalOptions="Center" 
                    HorizontalOptions="Center" />

                <Label x:Name="lblScore"
                       Text="0"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="MediumPurple"
                       VerticalOptions="Center" 
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Frame>

        <Image x:Name="champ"
            HeightRequest="150"
            Aspect="AspectFit"
            HorizontalOptions="Center"/>

        <HorizontalStackLayout HorizontalOptions="Center"
                   Spacing="6">

            <Label Text="🏆"
                FontSize="16" />

            <Label Text="Miglior Punteggio:"
               FontSize="16"
               TextColor="#f39c12"
               FontAttributes="Bold"/>

            <Label x:Name="BestScoreLabel"
               Text="0"
               FontSize="16"
               TextColor="#f39c12"
               FontAttributes="Bold"/>

        </HorizontalStackLayout>

        <!-- Clicked="OnRestartClicked" -->
        <Button Text="GIOCA ANCORA"
            HeightRequest="60"
            WidthRequest="200"
            FontSize="18"
            FontAttributes="Bold"
            CornerRadius="30"
            BackgroundColor="#5B3FD4"
            TextColor="White"/> 

    </VerticalStackLayout>
</ContentPage>